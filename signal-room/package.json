{
  "name": "signal-room",
  "version": "0.1.0",
  "private": true,
  "description": "Signal Room: Stuart Crowley's private prediction-markets editorial intelligence system. Turns industry noise, market activity and private context into the few content moves worth making today.",
  "scripts": {
    "dev": "next dev -p 4180",
    "build": "next build",
    "start": "next start -p 4180",
    "lint": "eslint src scripts tests e2e",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "db:reset": "tsx scripts/reset.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": "tsx scripts/eval.ts",
    "collect": "tsx scripts/collect.ts",
    "learn": "tsx scripts/learn-weights.ts",
    "briefing": "tsx scripts/briefing.ts",
    "shakedown": "tsx scripts/shakedown.ts",
    "e2e": "playwright test",
    "screenshots": "playwright test e2e/screenshots.spec.ts",
    "collect:inbox": "tsx scripts/inbox-collect.ts",
    "ingest:inbox": "tsx scripts/ingest-inbox.ts"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.3.4",
    "drizzle-orm": "^0.44.2",
    "fflate": "^0.8.2",
    "next": "^15.4.5",
    "pg": "^8.16.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tesseract.js": "^7.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@tailwindcss/postcss": "^4.1.11",
    "@types/node": "^22.15.0",
    "@types/pg": "^8.15.4",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9.32.0",
    "eslint-config-next": "^15.4.5",
    "tailwindcss": "^4.1.11",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
