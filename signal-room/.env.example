# Signal Room environment. Copy to .env.local for `next dev`, or export in the shell.
# Every variable is optional: with none set, Signal Room runs fully local
# (embedded PGlite database, deterministic mock intelligence provider, open access).

# --- Database -----------------------------------------------------------
# Leave unset to use the embedded PGlite (PostgreSQL-in-process) database at
# SIGNAL_ROOM_DATA_DIR (default ./.data/pglite). Set to a real PostgreSQL /
# Supabase connection string to use a server instead.
# DATABASE_URL=postgres://user:pass@localhost:5432/signal_room

# Where the embedded database and uploaded files live (default ./.data)
# SIGNAL_ROOM_DATA_DIR=./.data

# --- Intelligence provider ----------------------------------------------
# With ANTHROPIC_API_KEY set, editorial synthesis and drafting use Claude.
# Without it, Signal Room runs the deterministic heuristic provider ("mock"):
# the full pipeline works, drafts are evidence-quoting skeletons with
# bracketed slots instead of generated prose. The UI labels which is active.
# ANTHROPIC_API_KEY=sk-ant-...
# Strongest model, reserved for editorial judgement + drafting:
# SIGNAL_ROOM_EDITORIAL_MODEL=claude-opus-4-8
# Cheaper model for mechanical extraction refinement:
# SIGNAL_ROOM_EXTRACTION_MODEL=claude-haiku-4-5-20251001

# --- Access control -------------------------------------------------------
# Single-user private app. Set a passcode to require login; leave unset for
# open local access (the UI shows a LOCAL MODE badge so this is never silent).
# SIGNAL_ROOM_PASSCODE=choose-a-long-passphrase

# --- Limits ---------------------------------------------------------------
# Maximum accepted paste/upload size in characters (default 2,000,000).
# SIGNAL_ROOM_MAX_INPUT_CHARS=2000000
